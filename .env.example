# Arc Launchpad — example environment configuration.
# Copy to .env and fill in. Do NOT commit your real .env (it is gitignored).

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Secret used to sign session JWTs. The app refuses to start in production
# without it. Generate one with: openssl rand -hex 32
LAUNCHPAD_JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# RECOMMENDED (have sensible defaults, but you'll usually want to set these)
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL of this Launchpad deployment. Used for links in emails and as
# the WebAuthn (passkey) origin. Default: http://localhost:5173
LAUNCHPAD_BASE_URL=http://localhost:5173

# Path to the SQLite database file. Default: ./data/launchpad.db
# (The Docker image sets this to /app/data/launchpad.db.)
LAUNCHPAD_DB_PATH=./data/launchpad.db

# Display domain shown in the UI. Default: arc.localhost
LAUNCHPAD_DOMAIN=arc.localhost

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Email (Mailgun)
# Without these, transactional emails (verification, password reset, invites)
# are printed to the server console instead of being sent.
# ─────────────────────────────────────────────────────────────────────────────

# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_API_URL=https://api.mailgun.net      # use https://api.eu.mailgun.net for EU
# EMAIL_FROM=Arc Launchpad <noreply@example.com>

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Signup CAPTCHA (Cloudflare Turnstile)
# Without these, the signup CAPTCHA is skipped.
# ─────────────────────────────────────────────────────────────────────────────

# PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Ops alerting (Google Chat)
# Webhook to notify on silent server-side failures.
# ─────────────────────────────────────────────────────────────────────────────

# GCHAT_OPS_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — OAuth sign-in (GitHub / Google)
# The login UI does not show OAuth buttons by default. The server callback
# routes remain in the codebase; set these credentials (and re-enable the
# buttons) if you want OAuth sign-in.
# ─────────────────────────────────────────────────────────────────────────────

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
